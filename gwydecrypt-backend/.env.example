APP_NAME="GwydeCrypt"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# DATABASE - POSTGRESQL
# =============================================================================

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=gwydecrypt
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# Opciones adicionales de PostgreSQL
# DB_SCHEMA=public
# DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# GWYDECRYPT - ENVIRONMENT VARIABLES
# =============================================================================

# ⚠️  IMPORTANTE: Las API Keys NO van en este archivo
# =============================================================================
# Las API keys se gestionan desde el PANEL DE ADMINISTRACIÓN del backend
# en la tabla api_providers. Esto permite cambiarlas sin modificar el código
# ni reiniciar los servicios.
#
# Para añadir API keys:
# 1. Inicia sesión en http://localhost:8000/api/admin/providers
# 2. Añade o edita providers desde el panel
# 3. Las API keys se guardan encriptadas en la base de datos
#
# API URLs (fijas, pueden ir en .env):
COINGECKO_API_URL=https://api.coingecko.com/api/v3
ZERION_API_URL=https://api.zerion.io/v1
JUPITER_API_URL=https://price.jup.ag/v4

# Admin Emails (comma-separated)
ADMIN_EMAILS="admin@gwydecrypt.com"

# Database - PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=gwydecrypt
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# Cache & Queue
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# =============================================================================
# BLOCKCHAIN RPC ENDPOINTS
# =============================================================================
# Estas URLs de RPC también se pueden cambiar desde el panel admin
# si tienes endpoints propios o pagos (más rápidos/estables)

# Ethereum (Infura/Alchemy)
INFURA_PROJECT_ID=
INFURA_PROJECT_SECRET=
ETHEREUM_RPC_URL=https://eth.llamarpc.com

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Polygon
POLYGON_RPC_URL=https://polygon-rpc.com

# SUI
SUI_RPC_URL=https://fullnode.mainnet.sui.io

# =============================================================================
# LARAVEL SCHEDULER (CRON JOBS)
# =============================================================================

# The following commands will be run automatically:
# - Every 2 minutes: Fetch prices from APIs
# - Every 5 minutes: Sync active wallets
# - Every hour: Create portfolio snapshots
# - Daily at 2 AM: Database backup

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================
# 1. After setting up your .env file, run:
#    php artisan key:generate
#    php artisan migrate
#    php artisan db:seed
#
# 2. Default admin credentials:
#    Email: admin@gwydecrypt.com
#    Password: password (CHANGE IN PRODUCTION!)
#
# 3. Configurar API Keys desde Panel Admin:
#    - Login como admin
#    - Ir a POST /api/admin/providers
#    - Añadir API key en el campo api_key (se encripta automáticamente)
#    - Ejemplo: POST /api/admin/providers
#      {
#        "name": "zerion",
#        "base_url": "https://api.zerion.io/v1",
#        "api_key": "tu_api_key_aqui",
#        "is_active": true,
#        "priority": 2
#      }
#
# 4. El sistema viene con 3 providers pre-configurados por defecto:
#    - CoinGecko (activo) - No requiere API key para free tier
#    - Zerion (inactivo) - Requiere API key desde panel admin
#    - Jupiter (activo) - No requiere API key
#
# 5. To create a production build:
#    - Change APP_ENV=production
#    - Set APP_DEBUG=false
#    - Update admin emails
#    - Change default admin password
#    - Configure proper RPC endpoints
